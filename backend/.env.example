APP_NAME=TicketSystem
DEBUG=false
ENVIRONMENT=development
SECRET_KEY=change-me-in-production-use-a-long-random-string-here
DATABASE_URL=postgresql+asyncpg://ticketsystem:ticketsystem@localhost:5432/ticketsystem
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
TOTP_ISSUER=TicketSystem

# PostgreSQL (used by podman/docker compose and local dev db)
POSTGRES_USER=ticketsystem
POSTGRES_PASSWORD=ticketsystem
POSTGRES_DB=ticketsystem
